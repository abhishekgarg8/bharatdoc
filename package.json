{
  "name": "bharatdoc",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "audit:prod": "pnpm audit --prod --audit-level high",
    "check:phi-artifacts": "node scripts/check-phi-artifacts.mjs",
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @bharatdoc/web dev",
    "dev:worker": "pnpm --filter @bharatdoc/worker dev",
    "lint": "pnpm -r lint",
    "mobile:assets": "pnpm --filter @bharatdoc/mobile run assets",
    "mobile:build:android": "pnpm --filter @bharatdoc/mobile run build:android",
    "mobile:doctor": "pnpm --filter @bharatdoc/mobile run doctor",
    "mobile:open:android": "pnpm --filter @bharatdoc/mobile run open:android",
    "mobile:open:ios": "pnpm --filter @bharatdoc/mobile run open:ios",
    "mobile:sync": "pnpm --filter @bharatdoc/mobile run sync",
    "smoke:live-flow": "cd apps/web && node --env-file=../../.env ../../scripts/live-flow-smoke.mjs",
    "smoke:pwa": "cd apps/web && node ../../scripts/pwa-offline-smoke.mjs",
    "smoke:real-browser": "node --env-file=.env scripts/real-account-browser-e2e.mjs",
    "smoke:staging": "node --env-file=.env scripts/staging-smoke.mjs",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:e2e": "pnpm --filter @bharatdoc/web test:e2e",
    "typecheck": "pnpm -r typecheck",
    "with:current-supabase-anon": "node --env-file=.env scripts/with-current-supabase-anon-key.mjs --"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "16.2.10",
    "@railway/cli": "^4.42.1",
    "@types/node": "^22.15.3",
    "eslint": "^9.25.1",
    "prettier": "^3.5.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.1.2"
  },
  "pnpm": {
    "overrides": {
      "@babel/core@<7.29.6": "7.29.6",
      "form-data@<4.0.6": "4.0.6",
      "postcss@<8.5.10": "8.5.16",
      "qs@<6.15.2": "6.15.3",
      "ws@<8.21.0": "8.21.0"
    },
    "onlyBuiltDependencies": [
      "@railway/cli",
      "sharp"
    ]
  }
}
