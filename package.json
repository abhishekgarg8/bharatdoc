{
  "name": "bharatdoc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @bharatdoc/web dev",
    "dev:worker": "pnpm --filter @bharatdoc/worker dev",
    "lint": "pnpm -r lint",
    "smoke:live-flow": "cd apps/web && node --env-file=../../.env ../../scripts/live-flow-smoke.mjs",
    "smoke:pwa": "cd apps/web && node ../../scripts/pwa-offline-smoke.mjs",
    "smoke:staging": "node --env-file=.env scripts/staging-smoke.mjs",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:e2e": "pnpm --filter @bharatdoc/web test:e2e",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "eslint": "^9.25.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.2"
  }
}
