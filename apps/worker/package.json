{
  "name": "@bharatdoc/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @bharatdoc/shared build && tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src --ext .ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "typecheck": "pnpm --filter @bharatdoc/shared build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bharatdoc/shared": "workspace:*",
    "@fontsource/noto-sans": "^5.3.0",
    "@fontsource/noto-sans-devanagari": "^5.3.0",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/supabase-js": "2.110.4",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "5.2.1",
    "multer": "^1.4.5-lts.2",
    "openai": "^6.48.0",
    "react": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "@types/react": "19.2.17",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.4",
    "vitest": "^3.1.2"
  }
}
