{
  "name": "@bharatdoc/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @bharatdoc/shared build && next build",
    "dev": "pnpm --filter @bharatdoc/shared build && next dev",
    "lint": "eslint app components lib test e2e --ext .ts,.tsx",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "pnpm --filter @bharatdoc/shared build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bharatdoc/shared": "workspace:*",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@hookform/resolvers": "^3.10.0",
    "@supabase/supabase-js": "2.110.4",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb": "^8.0.2",
    "lucide-react": "^0.503.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recordrtc": "^5.6.2",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.3.2",
    "vitest": "^3.1.2"
  }
}
